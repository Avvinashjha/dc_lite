---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProblems, getProblemTopics, getProblemDifficulties, getProblemsIndex } from '../../utils/contentLoader';
import { slugifyTaxonomy } from '../../utils/taxonomy';

const pageMeta = getProblemsIndex();
const problems = getProblems();
const topics = getProblemTopics();
const difficulties = getProblemDifficulties();
const liteProblems = problems.map((problem) => ({
  slug: problem.slug,
  title: problem.title,
  topic: problem.topic,
  difficulty: problem.difficulty,
  confidence: Number(problem.confidence || 0),
}));
---

<BaseLayout title={`${pageMeta.title} | DailyCoder`} description={pageMeta.description}>
  <div class="container problems-page" style="padding-top: 2.4rem; padding-bottom: 3rem;">
    <section class="problems-hero">
      <p class="problems-hero__eyebrow">Practice Arena</p>
      <h1 class="problems-hero__title">{pageMeta.title}</h1>
      <p class="problems-hero__desc">{pageMeta.description}</p>
      <div class="problems-hero__chips">
        <span>{problems.length} curated problems</span>
        <span>JS runner enabled</span>
        <span>Local progress tracking</span>
      </div>
    </section>

    <nav class="problems-tabs" id="problems-tabs">
      <button class="problems-tabs__btn problems-tabs__btn--active" data-tab="list">Problems</button>
      <button class="problems-tabs__btn" data-tab="stats">Stats</button>
    </nav>

    <section class="problems-pane problems-pane--active" data-pane="list">
      <div class="problem-filters">
        <input id="problem-search" class="tool-input" placeholder="Search by title or topic..." />
        <select id="problem-topic" class="tool-input">
          <option value="all">All Topics</option>
          {topics.map((topic) => <option value={slugifyTaxonomy(topic)}>{topic}</option>)}
        </select>
        <select id="problem-difficulty" class="tool-input">
          <option value="all">All Difficulty</option>
          {difficulties.map((difficulty) => <option value={difficulty.toLowerCase()}>{difficulty}</option>)}
        </select>
      </div>

      <p id="problem-count" class="problem-count">{problems.length} problems</p>

      <div id="problem-grid" class="problem-grid">
        {problems.map((problem) => (
          <article
            class="problem-card"
            data-slug={problem.slug}
            data-title={problem.title.toLowerCase()}
            data-topic={slugifyTaxonomy(problem.topic)}
            data-difficulty={problem.difficulty.toLowerCase()}
            data-confidence={problem.confidence}
          >
            <div class="problem-card__head">
              <span class={`badge badge--${problem.difficulty.toLowerCase()}`}>{problem.difficulty}</span>
              <span class="badge badge--neutral">{problem.topic}</span>
              <span class="badge badge--status" data-status-for={problem.slug}>Not Solved</span>
            </div>
            <h3 class="problem-card__title">
              <a href={`/problems/${problem.slug}`}>{problem.title}</a>
            </h3>
            <p class="problem-card__meta">
              <span>{problem.platform}</span>
              <span>•</span>
              <span>{problem.status}</span>
              <span>•</span>
              <span data-attempts-for={problem.slug}>0 attempts</span>
            </p>
            <div class="problem-card__actions">
              <a class="button button--secondary" href={`/problems/${problem.slug}`}>Open</a>
              {problem.externalUrl && (
                <a class="button" href={problem.externalUrl} target="_blank" rel="noopener">Solve External</a>
              )}
              <button class="button button--ghost problem-solved-btn" data-solved-btn={problem.slug}>Mark Solved</button>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="problems-pane" data-pane="stats">
      <div class="stats-grid">
        <article class="stats-card">
          <p class="stats-card__label">Solved</p>
          <p class="stats-card__value" id="stat-solved">0</p>
          <p class="stats-card__hint" id="stat-solved-rate">0% completion</p>
        </article>
        <article class="stats-card">
          <p class="stats-card__label">Attempts</p>
          <p class="stats-card__value" id="stat-attempts">0</p>
          <p class="stats-card__hint">Total runs from JS runner</p>
        </article>
        <article class="stats-card">
          <p class="stats-card__label">Active Days</p>
          <p class="stats-card__value" id="stat-days">0</p>
          <p class="stats-card__hint">Days with at least one attempt</p>
        </article>
        <article class="stats-card">
          <p class="stats-card__label">Avg Topic Confidence</p>
          <p class="stats-card__value" id="stat-confidence">0%</p>
          <p class="stats-card__hint">From solved problems</p>
        </article>
      </div>

      <div class="charts-grid">
        <article class="chart-card">
          <h3>Daily Activity</h3>
          <div id="chart-daily" class="mini-bars"></div>
        </article>
        <article class="chart-card">
          <h3>Topic-wise Solved</h3>
          <div id="chart-topic-solved" class="stat-bars"></div>
        </article>
        <article class="chart-card">
          <h3>Topic Confidence</h3>
          <div id="chart-topic-confidence" class="stat-bars"></div>
        </article>
        <article class="chart-card">
          <h3>Most Attempted Problems</h3>
          <div id="attempts-table" class="attempts-table"></div>
        </article>
      </div>
    </section>
  </div>
</BaseLayout>

<script id="problems-data" type="application/json" set:html={JSON.stringify(liteProblems)} />
<script src="/js/store.js" is:inline></script>
<script>
  var TOOL = 'problem-progress';
  var problemsData = JSON.parse(document.getElementById('problems-data').textContent || '[]');
  var bySlug = {};
  problemsData.forEach(function(problem) { bySlug[problem.slug] = problem; });

  var tabButtons = Array.prototype.slice.call(document.querySelectorAll('.problems-tabs__btn'));
  var panes = Array.prototype.slice.call(document.querySelectorAll('.problems-pane'));
  var searchEl = document.getElementById('problem-search');
  var topicEl = document.getElementById('problem-topic');
  var difficultyEl = document.getElementById('problem-difficulty');
  var countEl = document.getElementById('problem-count');
  var cards = Array.prototype.slice.call(document.querySelectorAll('.problem-card'));
  var progressMap = {};
  var dailyEl = document.getElementById('chart-daily');
  var topicSolvedEl = document.getElementById('chart-topic-solved');
  var topicConfidenceEl = document.getElementById('chart-topic-confidence');

  function switchTab(tabName) {
    tabButtons.forEach(function(btn) {
      btn.classList.toggle('problems-tabs__btn--active', btn.dataset.tab === tabName);
    });
    panes.forEach(function(pane) {
      pane.classList.toggle('problems-pane--active', pane.dataset.pane === tabName);
    });
    if (tabName === 'stats') renderStats();
  }

  tabButtons.forEach(function(btn) {
    btn.addEventListener('click', function() { switchTab(btn.dataset.tab); });
  });

  function attemptWord(n) { return n === 1 ? 'attempt' : 'attempts'; }

  function renderCardState(slug) {
    var row = progressMap[slug] || { solved: false, attempts: 0 };
    var statusEl = document.querySelector('[data-status-for="' + slug + '"]');
    var attemptsEl = document.querySelector('[data-attempts-for="' + slug + '"]');
    var btn = document.querySelector('[data-solved-btn="' + slug + '"]');
    var card = document.querySelector('.problem-card[data-slug="' + slug + '"]');
    if (!statusEl || !attemptsEl || !btn || !card) return;

    statusEl.textContent = row.solved ? 'Solved' : 'Not Solved';
    statusEl.classList.toggle('badge--done', !!row.solved);
    attemptsEl.textContent = (row.attempts || 0) + ' ' + attemptWord(row.attempts || 0);
    btn.textContent = row.solved ? 'Mark Unsolved' : 'Mark Solved';
    card.classList.toggle('problem-card--solved', !!row.solved);
  }

  function renderAllCardsState() {
    cards.forEach(function(card) { renderCardState(card.dataset.slug); });
  }

  function applyFilters() {
    var search = (searchEl.value || '').trim().toLowerCase();
    var topic = topicEl.value;
    var difficulty = difficultyEl.value;
    var visible = 0;

    cards.forEach(function(card) {
      var title = card.dataset.title || '';
      var cardTopic = card.dataset.topic || '';
      var cardDifficulty = card.dataset.difficulty || '';
      var matchesSearch = !search || title.indexOf(search) !== -1 || cardTopic.indexOf(search) !== -1;
      var matchesTopic = topic === 'all' || cardTopic === topic;
      var matchesDifficulty = difficulty === 'all' || cardDifficulty === difficulty;
      var show = matchesSearch && matchesTopic && matchesDifficulty;
      card.style.display = show ? '' : 'none';
      if (show) visible += 1;
    });

    countEl.textContent = visible + ' problem' + (visible === 1 ? '' : 's');
  }

  async function loadProgress() {
    await DCStore.init();
    var rows = await DCStore.getAll(TOOL);
    progressMap = {};
    rows.forEach(function(row) {
      progressMap[row.id] = {
        solved: !!row.solved,
        solvedAt: row.solvedAt || null,
        attempts: Number(row.attempts || 0),
        lastAttemptAt: row.lastAttemptAt || null,
        attemptsByDay: row.attemptsByDay || {},
      };
    });
  }

  async function setSolved(slug, solved) {
    var existing = progressMap[slug] || { attempts: 0, attemptsByDay: {} };
    var next = {
      solved: solved,
      solvedAt: solved ? (existing.solvedAt || Date.now()) : null,
      attempts: Number(existing.attempts || 0),
      lastAttemptAt: existing.lastAttemptAt || null,
      attemptsByDay: existing.attemptsByDay || {},
    };
    progressMap[slug] = next;
    await DCStore.set(TOOL, slug, next);
    renderCardState(slug);
    renderStats();
  }

  function bindSolvedButtons() {
    document.querySelectorAll('.problem-solved-btn').forEach(function(btn) {
      btn.addEventListener('click', async function() {
        var slug = btn.dataset.solvedBtn;
        var row = progressMap[slug] || { solved: false };
        await setSolved(slug, !row.solved);
      });
    });
  }

  function buildAggregates() {
    var solvedCount = 0;
    var totalAttempts = 0;
    var attemptsByDay = {};
    var topicSolved = {};
    var topicConfidence = {};
    var topicConfidenceCount = {};
    var attemptsByProblem = [];

    Object.keys(bySlug).forEach(function(slug) {
      var p = bySlug[slug];
      var row = progressMap[slug] || { solved: false, attempts: 0, attemptsByDay: {} };
      var topic = p.topic || 'Other';
      if (!topicSolved[topic]) topicSolved[topic] = 0;
      if (!topicConfidence[topic]) topicConfidence[topic] = 0;
      if (!topicConfidenceCount[topic]) topicConfidenceCount[topic] = 0;

      if (row.solved) {
        solvedCount += 1;
        topicSolved[topic] += 1;
        topicConfidence[topic] += Number(p.confidence || 0);
        topicConfidenceCount[topic] += 1;
      }

      var attempts = Number(row.attempts || 0);
      totalAttempts += attempts;
      if (attempts > 0) {
        attemptsByProblem.push({ slug: slug, title: p.title, attempts: attempts });
      }

      var perDay = row.attemptsByDay || {};
      Object.keys(perDay).forEach(function(day) {
        attemptsByDay[day] = Number(attemptsByDay[day] || 0) + Number(perDay[day] || 0);
      });
    });

    var topicConfidencePercent = {};
    Object.keys(topicConfidence).forEach(function(topic) {
      var count = Number(topicConfidenceCount[topic] || 0);
      topicConfidencePercent[topic] = count > 0
        ? Math.round((topicConfidence[topic] / count) * 100)
        : 0;
    });

    attemptsByProblem.sort(function(a, b) { return b.attempts - a.attempts; });

    return {
      solvedCount: solvedCount,
      totalAttempts: totalAttempts,
      attemptsByDay: attemptsByDay,
      topicSolved: topicSolved,
      topicConfidence: topicConfidencePercent,
      attemptsByProblem: attemptsByProblem,
    };
  }

  function lastNDays(n) {
    var out = [];
    for (var i = n - 1; i >= 0; i -= 1) {
      var d = new Date();
      d.setHours(0, 0, 0, 0);
      d.setDate(d.getDate() - i);
      out.push(d.toISOString().slice(0, 10));
    }
    return out;
  }

  function renderStats() {
    var agg = buildAggregates();
    var solvedRate = problemsData.length ? Math.round((agg.solvedCount / problemsData.length) * 100) : 0;
    var activeDays = Object.keys(agg.attemptsByDay).filter(function(day) { return agg.attemptsByDay[day] > 0; }).length;

    document.getElementById('stat-solved').textContent = String(agg.solvedCount);
    document.getElementById('stat-solved-rate').textContent = solvedRate + '% completion';
    document.getElementById('stat-attempts').textContent = String(agg.totalAttempts);
    document.getElementById('stat-days').textContent = String(activeDays);

    var topicKeys = Object.keys(agg.topicConfidence);
    var avgConfidence = topicKeys.length
      ? Math.round(topicKeys.reduce(function(sum, key) { return sum + (agg.topicConfidence[key] || 0); }, 0) / topicKeys.length)
      : 0;
    document.getElementById('stat-confidence').textContent = avgConfidence + '%';

    var dayLabels = lastNDays(21);
    var dayData = dayLabels.map(function(day) { return Number(agg.attemptsByDay[day] || 0); });
    var maxDay = Math.max.apply(null, dayData.concat([1]));
    dailyEl.innerHTML = dayData.map(function(count, idx) {
      var h = Math.max(6, Math.round((count / maxDay) * 92));
      var label = dayLabels[idx].slice(5);
      return '<div class="mini-bars__item" title="' + label + ': ' + count + '">' +
        '<span class="mini-bars__bar" style="height:' + h + '%"></span>' +
        '<span class="mini-bars__label">' + label + '</span>' +
      '</div>';
    }).join('');

    var solvedEntries = Object.entries(agg.topicSolved).sort(function(a, b) { return b[1] - a[1]; }).slice(0, 10);
    var solvedMax = Math.max.apply(null, solvedEntries.map(function(entry) { return entry[1]; }).concat([1]));
    topicSolvedEl.innerHTML = solvedEntries.length
      ? solvedEntries.map(function(entry) {
          var width = Math.max(3, Math.round((entry[1] / solvedMax) * 100));
          return '<div class="stat-bars__row">' +
            '<span class="stat-bars__name">' + entry[0] + '</span>' +
            '<span class="stat-bars__track"><span class="stat-bars__fill stat-bars__fill--green" style="width:' + width + '%"></span></span>' +
            '<span class="stat-bars__value">' + entry[1] + '</span>' +
          '</div>';
        }).join('')
      : '<p style="color:var(--color-text-light);">No solved data yet.</p>';

    var confidenceEntries = Object.entries(agg.topicConfidence).sort(function(a, b) { return b[1] - a[1]; }).slice(0, 10);
    var confidenceMax = Math.max.apply(null, confidenceEntries.map(function(entry) { return entry[1]; }).concat([1]));
    topicConfidenceEl.innerHTML = confidenceEntries.length
      ? confidenceEntries.map(function(entry) {
          var width = Math.max(3, Math.round((entry[1] / confidenceMax) * 100));
          return '<div class="stat-bars__row">' +
            '<span class="stat-bars__name">' + entry[0] + '</span>' +
            '<span class="stat-bars__track"><span class="stat-bars__fill stat-bars__fill--amber" style="width:' + width + '%"></span></span>' +
            '<span class="stat-bars__value">' + entry[1] + '%</span>' +
          '</div>';
        }).join('')
      : '<p style="color:var(--color-text-light);">No confidence data yet.</p>';

    var attemptsRows = agg.attemptsByProblem.slice(0, 10);
    var tableEl = document.getElementById('attempts-table');
    if (!attemptsRows.length) {
      tableEl.innerHTML = '<p style="color:var(--color-text-light);">No attempts yet.</p>';
      return;
    }
    tableEl.innerHTML = attemptsRows.map(function(row, idx) {
      return '<div class="attempts-row">' +
        '<span class="attempts-row__rank">#' + (idx + 1) + '</span>' +
        '<a class="attempts-row__title" href="/problems/' + row.slug + '">' + row.title + '</a>' +
        '<span class="attempts-row__count">' + row.attempts + '</span>' +
      '</div>';
    }).join('');
  }

  searchEl.addEventListener('input', applyFilters);
  topicEl.addEventListener('change', applyFilters);
  difficultyEl.addEventListener('change', applyFilters);

  (async function init() {
    await loadProgress();
    renderAllCardsState();
    bindSolvedButtons();
    applyFilters();
    renderStats();
  })();
</script>

<style>
  .problems-hero {
    background:
      radial-gradient(1200px 280px at 20% -20%, rgba(37,99,235,.18), transparent 55%),
      radial-gradient(800px 220px at 90% 0%, rgba(16,185,129,.12), transparent 55%),
      var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl, 18px);
    padding: 1.2rem 1.2rem 1rem;
    margin-bottom: 1rem;
  }
  .problems-hero__eyebrow {
    text-transform: uppercase;
    letter-spacing: .12em;
    font-size: .72rem;
    color: var(--color-text-light);
    margin: 0 0 .35rem;
    font-weight: 700;
  }
  .problems-hero__title {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.05;
  }
  .problems-hero__desc {
    margin: .55rem 0 .8rem;
    color: var(--color-text-light);
    max-width: 72ch;
  }
  .problems-hero__chips {
    display: flex;
    flex-wrap: wrap;
    gap: .4rem;
  }
  .problems-hero__chips span {
    font-size: .75rem;
    padding: .22rem .55rem;
    border-radius: 999px;
    background: var(--color-code-bg);
    color: var(--color-text-light);
    border: 1px solid var(--color-border);
  }

  .problems-tabs {
    display: inline-flex;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    margin: .25rem 0 1rem;
  }
  .problems-tabs__btn {
    border: 0;
    background: var(--color-surface);
    color: var(--color-text-light);
    padding: .48rem .9rem;
    font-weight: 700;
    cursor: pointer;
  }
  .problems-tabs__btn--active {
    background: var(--color-primary);
    color: #fff;
  }
  .problems-pane { display: none; }
  .problems-pane--active { display: block; }

  .problem-filters {
    display: grid;
    gap: 0.6rem;
    grid-template-columns: 1.4fr 1fr 1fr;
    margin-bottom: 0.5rem;
  }
  .problem-filters .tool-input {
    width: 100%;
    height: 44px;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: color-mix(in oklab, var(--color-surface) 88%, var(--color-code-bg) 12%);
    color: var(--color-text);
    font-size: 0.95rem;
    font-family: var(--font-body, inherit);
    padding: 0 0.9rem;
    box-shadow: inset 0 1px 0 rgba(255,255,255,.06);
    transition: border-color 140ms ease, box-shadow 140ms ease, background 140ms ease;
  }
  .problem-filters input.tool-input::placeholder {
    color: var(--color-text-light);
    opacity: .85;
  }
  .problem-filters select.tool-input {
    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;
    padding-right: 2.2rem;
    background-image:
      linear-gradient(45deg, transparent 50%, var(--color-text-light) 50%),
      linear-gradient(135deg, var(--color-text-light) 50%, transparent 50%);
    background-position:
      calc(100% - 18px) 18px,
      calc(100% - 13px) 18px;
    background-size: 5px 5px, 5px 5px;
    background-repeat: no-repeat;
  }
  .problem-filters .tool-input:hover {
    border-color: color-mix(in oklab, var(--color-primary) 45%, var(--color-border));
  }
  .problem-filters .tool-input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--color-primary) 20%, transparent);
    background: var(--color-surface);
  }
  .problem-count {
    margin: .6rem 0 1rem;
    color: var(--color-text-light);
    font-size: .9rem;
  }
  .problem-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: .95rem;
  }
  .problem-card {
    border: 1px solid var(--color-border);
    border-radius: 16px;
    background: linear-gradient(180deg, color-mix(in oklab, var(--color-surface) 84%, var(--color-primary) 16%), var(--color-surface));
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: .7rem;
    transition: transform 160ms ease, box-shadow 160ms ease, border-color 160ms ease;
  }
  .problem-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(0,0,0,.08);
    border-color: color-mix(in oklab, var(--color-primary) 35%, var(--color-border));
  }
  .problem-card--solved {
    border-color: rgba(34,197,94,.5);
    background: linear-gradient(180deg, color-mix(in oklab, var(--color-surface) 84%, #22c55e 16%), var(--color-surface));
  }
  .problem-card__head { display:flex; gap:.42rem; flex-wrap:wrap; }
  .problem-card__title { margin: 0; font-size: 1.06rem; line-height: 1.35; }
  .problem-card__title a { color: var(--color-text); text-decoration: none; }
  .problem-card__title a:hover { color: var(--color-primary); }
  .problem-card__meta {
    margin: 0;
    display: flex;
    gap: .35rem;
    color: var(--color-text-light);
    font-size: .82rem;
    flex-wrap: wrap;
  }
  .problem-card__actions {
    margin-top: auto;
    display: flex;
    gap: .45rem;
    flex-wrap: wrap;
  }
  .button--ghost {
    background: transparent;
    border: 1px dashed var(--color-border);
    color: var(--color-text-light);
  }
  .button--ghost:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .badge {
    display: inline-block;
    font-size: .72rem;
    font-weight: 800;
    padding: .17rem .55rem;
    border-radius: 999px;
  }
  .badge--easy { background: rgba(34,197,94,.18); color: #16a34a; }
  .badge--medium { background: rgba(245,158,11,.2); color: #d97706; }
  .badge--hard { background: rgba(239,68,68,.2); color: #dc2626; }
  .badge--neutral { background: var(--color-code-bg); color: var(--color-text-light); }
  .badge--status { background: rgba(148,163,184,.18); color: #64748b; margin-left: auto; }
  .badge--status.badge--done { background: rgba(34,197,94,.18); color: #16a34a; }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: .75rem;
    margin-bottom: .9rem;
  }
  .stats-card {
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: .8rem;
    background: var(--color-surface);
  }
  .stats-card__label {
    margin: 0;
    font-size: .74rem;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--color-text-light);
    font-weight: 700;
  }
  .stats-card__value {
    margin: .25rem 0 .15rem;
    font-size: 1.9rem;
    line-height: 1;
    font-weight: 800;
  }
  .stats-card__hint {
    margin: 0;
    color: var(--color-text-light);
    font-size: .78rem;
  }
  .charts-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: .8rem;
  }
  .chart-card {
    border: 1px solid var(--color-border);
    border-radius: 14px;
    background: var(--color-surface);
    padding: .9rem;
    min-height: 290px;
  }
  .chart-card h3 {
    margin: 0 0 .55rem;
