---
import fs from 'node:fs';
import path from 'node:path';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import Subscribe from '../components/Subscribe.astro';
import {
  getBlogPostsSorted,
  getCourses,
  getTodaysProblem,
  getPastDailyProblems,
  getDailyScheduleFullLite,
  getProblem,
  getProblems,
} from '../utils/contentLoader';
import { TOOLS_COUNT, ALL_TOOLS } from '../data/tools';

// ── Dynamic content ──────────────────────────────────────
const recentPosts = getBlogPostsSorted().slice(0, 3);
const firstPost = recentPosts[0];
const courses = getCourses();
const allProblems = getProblems();

const toolsCount = TOOLS_COUNT;
const problemCount = allProblems.length;
const articleCount = getBlogPostsSorted().length;
const courseCount = courses.length;
const featuredTools = ALL_TOOLS.slice(0, 8);

// Quiz + games counts are derived from disk so they stay live as the
// quiz module lands. Defensive: a half-written file should never break the build.
function countQuizzes(): number {
  try {
    const dir = path.resolve(process.cwd(), 'content', 'quiz');
    if (!fs.existsSync(dir)) return 0;
    return fs
      .readdirSync(dir, { withFileTypes: true })
      .filter((d) => d.isDirectory() && fs.existsSync(path.join(dir, d.name, 'quiz.json'))).length;
  } catch {
    return 0;
  }
}

function countGames(): number {
  try {
    const dir = path.resolve(process.cwd(), 'src', 'pages', 'games');
    if (!fs.existsSync(dir)) return 0;
    return fs.readdirSync(dir).filter((f) => f.endsWith('.astro') && f !== 'index.astro').length;
  } catch {
    return 0;
  }
}

const quizCount = countQuizzes();
const gamesCount = countGames();

// ── Problem of the day ───────────────────────────────────
const todaysProblem = getTodaysProblem();
const recentPotd = getPastDailyProblems().slice(0, 5);
const scheduleFullLite = getDailyScheduleFullLite();
const potdFull = todaysProblem ? getProblem(todaysProblem.slug) : null;

function textExcerpt(html: string, max = 200): string {
  if (!html) return '';
  const t = html.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
  return t.length > max ? t.slice(0, max).trimEnd() + '…' : t;
}

const potdExcerpt = potdFull ? textExcerpt(potdFull.descriptionHtml) : '';

function diffClass(d: string) {
  const x = d.toLowerCase();
  return x === 'easy' || x === 'medium' || x === 'hard' ? x : 'neutral';
}

const potdHref = todaysProblem ? `/problems/${todaysProblem.slug}` : '/problems';

// ── Stats strip ──────────────────────────────────────────
const stats = [
  { value: toolsCount, label: 'Dev Tools', href: '/tools' },
  { value: problemCount, label: 'Problems', href: '/problems' },
  { value: articleCount, label: 'Articles', href: '/blog' },
  { value: quizCount, label: 'Quizzes', href: '/quiz' },
  { value: courseCount, label: 'Courses', href: '/courses' },
  { value: gamesCount, label: 'Games', href: '/games' },
].filter((s) => s.value > 0);

// ── Feature grid ─────────────────────────────────────────
const features = [
  {
    icon: '🔧',
    title: 'Developer Tools',
    href: '/tools',
    desc: `${toolsCount} private, client-side tools. Nothing you paste ever leaves your browser.`,
    highlights: ['JSON Formatter', 'Diff Checker', 'Regex Tester', 'JWT Decoder'],
    accent: 'tools',
  },
  {
    icon: '⚡',
    title: 'Coding Problems',
    href: '/problems',
    desc: `${problemCount} LeetCode-style problems with a built-in JavaScript editor, test cases & instant feedback.`,
    highlights: ['In-browser editor', 'Daily challenge', 'Progress sync'],
    accent: 'problems',
  },
  {
    icon: '🧠',
    title: 'Quizzes',
    href: '/quiz',
    desc: 'Test your knowledge with interactive quizzes. Practice freely or compete on ranked leaderboards.',
    highlights: ['JavaScript', 'CSS', 'HTTP & Web'],
    accent: 'quiz',
    isNew: true,
  },
  {
    icon: '✍️',
    title: 'Blog & Articles',
    href: '/blog',
    desc: 'Engineering deep-dives, architecture patterns, and practical career advice for working developers.',
    highlights: ['Deep-dives', 'Patterns', 'Career tips'],
    accent: 'blog',
  },
  {
    icon: '🎓',
    title: 'Courses',
    href: '/courses',
    desc: 'Hands-on, interactive courses with lesson tracking and progress saved right on your device.',
    highlights: ['Self-paced', 'Lesson tracking', 'Free forever'],
    accent: 'courses',
  },
  {
    icon: '🎮',
    title: 'Games',
    href: '/games',
    desc: 'Take a break with free browser games — no download, no signup, instant play.',
    highlights: ['Snake', 'Tetris', 'Sudoku', 'Chess'],
    accent: 'games',
  },
];

// ── SEO ──────────────────────────────────────────────────
const pageKeywords = [
  'free developer tools',
  'coding problems',
  'in-browser javascript editor',
  'programming quizzes',
  'coding courses',
  'daily coding challenge',
  ...(todaysProblem ? [todaysProblem.title, todaysProblem.topic] : []),
].join(', ');

const jsonLdPotd = todaysProblem
  ? {
      '@context': 'https://schema.org',
      '@type': 'LearningResource',
      name: `Daily Challenge: ${todaysProblem.title}`,
      description: `Solve ${todaysProblem.title} — a ${todaysProblem.difficulty} ${todaysProblem.topic} problem — in the browser with an integrated editor.`,
      educationalLevel: todaysProblem.difficulty,
      learningResourceType: 'Coding Problem',
      url: `https://dailycoder.in/problems/${todaysProblem.slug}`,
      datePublished: todaysProblem.publishedAt || undefined,
    }
  : null;
---

<BaseLayout
  title="DailyCoder — Free Dev Tools, Coding Problems, Quizzes & Courses"
  description="Free tools, problems, courses, quizzes & games for coders. Solve daily challenges in-browser, read engineering deep-dives, and use private dev tools. No signup needed."
  tags={pageKeywords.split(', ')}
>
  <Fragment slot="head">
    {jsonLdPotd && <script type="application/ld+json" set:html={JSON.stringify(jsonLdPotd)} />}
  </Fragment>

  <!-- ── HERO ─────────────────────────────────────────── -->
  <section class="hp-hero" aria-label="Site introduction">
    <div class="container hp-hero__inner">
      <div class="hp-hero__text">
        <p class="hp-hero__eyebrow">Free · No signup · Runs in your browser</p>
        <h1 class="hp-hero__title">
          Everything you need to<br /><span class="hp-hero__accent">level up as a coder.</span>
        </h1>
        <p class="hp-hero__sub">
          Free developer tools, {problemCount} coding problems, hands-on courses, quizzes and
          games — all running right in your browser. No tracking, no limits.
        </p>
        <div class="hp-hero__ctas">
          <a href="/tools" class="button">Explore {toolsCount} tools</a>
          <a href={potdHref} class="button button--secondary">
            {todaysProblem ? "Solve today's problem" : 'Solve problems'}
          </a>
        </div>
        <div class="hp-hero__pills" aria-label="Browse sections">
          <a href="/problems" class="hp-pill">{problemCount} Problems</a>
          <a href="/quiz" class="hp-pill">Quizzes</a>
          <a href="/courses" class="hp-pill">Courses</a>
          <a href="/games" class="hp-pill">{gamesCount} Games</a>
          <a href="/blog" class="hp-pill">Articles</a>
        </div>
      </div>

      <div class="hp-hero__card" aria-hidden="true">
        <div class="hp-hero__card-header">
          <span class="hp-hero__card-dot hp-hero__card-dot--red"></span>
          <span class="hp-hero__card-dot hp-hero__card-dot--yellow"></span>
          <span class="hp-hero__card-dot hp-hero__card-dot--green"></span>
          <span class="hp-hero__card-filename">solution.js</span>
        </div>
        <pre class="hp-hero__code"><code><span class="hp-c-keyword">function</span> <span class="hp-c-fn">isValid</span>(s) {'{'}
  <span class="hp-c-keyword">const</span> map = {'{'} <span class="hp-c-str">&#39;)&#39;</span>: <span class="hp-c-str">&#39;(&#39;</span>, <span class="hp-c-str">&#39;]&#39;</span>: <span class="hp-c-str">&#39;[&#39;</span>, <span class="hp-c-str">&#39;&#125;&#39;</span>: <span class="hp-c-str">&#39;{'{'}&#39;</span> {'}'};
  <span class="hp-c-keyword">const</span> stack = [];
  <span class="hp-c-keyword">for</span> (<span class="hp-c-keyword">const</span> c <span class="hp-c-keyword">of</span> s) {'{'}
    <span class="hp-c-keyword">if</span> (map[c]) {'{'}
      <span class="hp-c-keyword">if</span> (stack.pop() !== map[c]) <span class="hp-c-keyword">return</span> <span class="hp-c-keyword">false</span>;
    {'}'} <span class="hp-c-keyword">else</span> stack.push(c);
  {'}'}
  <span class="hp-c-keyword">return</span> !stack.length;
{'}'}</code></pre>
      </div>
    </div>
  </section>

  <!-- ── STATS STRIP ──────────────────────────────────── -->
  <section class="hp-stats-wrap" aria-label="What's on DailyCoder">
    <div class="container hp-stats">
      {stats.map((s) => (
        <a href={s.href} class="hp-stat-tile">
          <span class="hp-stat-tile__val">{s.value}</span>
          <span class="hp-stat-tile__lbl">{s.label}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- ── FEATURE GRID ─────────────────────────────────── -->
  <section class="hp-section container" aria-labelledby="explore-heading">
    <div class="hp-section__hd">
      <div>
        <h2 id="explore-heading">Explore the platform</h2>
        <p class="hp-section__sub">Six free toolkits to learn, build and ship — pick where you want to start.</p>
      </div>
    </div>
    <div class="hp-feature-grid">
      {features.map((f) => (
        <a href={f.href} class={`hp-card hp-card--${f.accent}`}>
          <div class="hp-card__top">
            <span class="hp-card__icon" aria-hidden="true">{f.icon}</span>
            {f.isNew && <span class="hp-card__new">New</span>}
          </div>
          <h3 class="hp-card__title">{f.title}</h3>
          <p class="hp-card__desc">{f.desc}</p>
          <div class="hp-card__chips">
            {f.highlights.map((h) => (
              <span class="hp-card__chip">{h}</span>
            ))}
          </div>
          <span class="hp-card__link">Explore <span aria-hidden="true">→</span></span>
        </a>
      ))}
    </div>
  </section>

  <!-- ── PROBLEM OF THE DAY ───────────────────────────── -->
  <section id="daily-challenge" class="hp-section container" aria-labelledby="potd-heading">
    <div class="hp-section__hd">
      <div>
        <h2 id="potd-heading-top" class="hp-section__title-row"><span class="hp-section__dot"></span>Problem of the day</h2>
        <p class="hp-section__sub">A fresh, hand-picked challenge to solve in the browser every day.</p>
      </div>
      <a href="/problems" class="hp-text-link">All problems →</a>
    </div>
    <div class="hp-potd">
      <div class="hp-potd__aside">
        <p class="hp-eyebrow">Your progress</p>
        {todaysProblem && <p class="hp-potd__date">{todaysProblem.publishedAt}</p>}
        <div class="hp-potd__stats" aria-label="Your daily progress">
          <div class="hp-stat"><span class="hp-stat__val" id="hp-streak">—</span><span class="hp-stat__lbl">Streak</span></div>
          <div class="hp-stat"><span class="hp-stat__val" id="hp-solved">—</span><span class="hp-stat__lbl">Solved</span></div>
          <div class="hp-stat"><span class="hp-stat__val" id="hp-best">—</span><span class="hp-stat__lbl">Best</span></div>
        </div>
        <p class="hp-potd__stats-note">Sign in to sync progress across devices.</p>
        {recentPotd.length > 0 && (
          <div class="hp-potd__recents">
            <p class="hp-potd__recents-label">Recent picks</p>
            <ul>
              {recentPotd.map((p) => (
                <li>
                  <a href={`/problems/${p.slug}`}>{p.title}</a>
                  <span>{p.publishedAt}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>

      <div class="hp-potd__main">
        {todaysProblem ? (
          <>
            <div class="hp-potd__badges">
              <span class="hp-badge hp-badge--neutral">{todaysProblem.topic}</span>
              <span class={`hp-badge hp-badge--${diffClass(todaysProblem.difficulty)}`}>{todaysProblem.difficulty}</span>
              {todaysProblem.platform && <span class="hp-badge hp-badge--neutral">{todaysProblem.platform}</span>}
            </div>
            <h3 id="potd-heading" class="hp-potd__title">{todaysProblem.title}</h3>
            {potdExcerpt && <p class="hp-potd__excerpt">{potdExcerpt}</p>}
            {(todaysProblem.sampleInput || todaysProblem.sampleOutput) && (
              <div class="hp-potd__io">
                {todaysProblem.sampleInput && (
                  <div class="hp-potd__io-block">
                    <div class="hp-potd__io-label">Input</div>
                    <pre class="hp-potd__io-body">{todaysProblem.sampleInput}</pre>
                  </div>
                )}
                {todaysProblem.sampleOutput && (
                  <div class="hp-potd__io-block">
                    <div class="hp-potd__io-label">Output</div>
                    <pre class="hp-potd__io-body">{todaysProblem.sampleOutput}</pre>
                  </div>
                )}
              </div>
            )}
            <div class="hp-potd__actions">
              <a class="button" href={potdHref}>Solve in editor</a>
              <a class="hp-text-link" href="/problems">Browse all problems →</a>
            </div>
          </>
        ) : (
          <>
            <h3 id="potd-heading" class="hp-potd__title">Practise at your own pace</h3>
            <p class="hp-potd__excerpt">No challenge is scheduled right now — browse the full catalog and solve anything in the in-browser editor.</p>
            <a class="button" href="/problems">Open problem list</a>
          </>
        )}
      </div>
    </div>
  </section>

  <!-- ── FEATURED TOOLS ───────────────────────────────── -->
  <section class="hp-section container" aria-labelledby="tools-heading">
    <div class="hp-section__hd">
      <div>
        <h2 id="tools-heading">Popular developer tools</h2>
        <p class="hp-section__sub">Private &amp; free — your data never leaves your browser.</p>
      </div>
      <a href="/tools" class="hp-text-link">All {toolsCount} tools →</a>
    </div>
    <div class="hp-tools">
      {featuredTools.map((t) => (
        <a href={t.href} class="hp-tool">
          <span class="hp-tool__icon">{t.icon}</span>
          <span class="hp-tool__name">{t.name}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- ── BLOG POSTS ────────────────────────────────────── -->
  {recentPosts.length > 0 && (
    <section class="hp-section container" aria-labelledby="blog-heading">
      <div class="hp-section__hd">
        <div>
          <h2 id="blog-heading">From the blog</h2>
          <p class="hp-section__sub">Engineering deep-dives and practical guides.</p>
        </div>
        <a href="/blog" class="hp-text-link">View all →</a>
      </div>
      <div class="grid grid--3">
        {recentPosts.map((post) => (
          <PostCard
            title={post.title}
            description={post.description}
            date={new Date(post.date)}
            slug={post.slug}
            tags={post.tags}
            category={post.category}
            image={post.image}
            content={post.content}
          />
        ))}
      </div>
    </section>
  )}

  <!-- ── COURSES ───────────────────────────────────────── -->
  {courses.length > 0 && (
    <section class="hp-section container" aria-labelledby="courses-heading">
      <div class="hp-section__hd">
        <div>
          <h2 id="courses-heading">Courses</h2>
          <p class="hp-section__sub">Self-paced, hands-on, and free.</p>
        </div>
        <a href="/courses" class="hp-text-link">View all →</a>
      </div>
      <div class="hp-course-list">
        {courses.slice(0, 4).map((course) => (
          <a href={`/courses/${course.slug}`} class="hp-course-row">
            <div class="hp-course-row__body">
              <span class="hp-course-row__title">{course.title}</span>
              <span class="hp-course-row__meta">{course.level} · {course.totalLessons} lessons · {course.duration}</span>
            </div>
            <span class="hp-course-row__arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- ── SUBSCRIBE ─────────────────────────────────────── -->
  <section class="hp-subscribe">
    <div class="container">
      <Subscribe />
    </div>
  </section>
</BaseLayout>

<script id="home-daily-schedule" type="application/json" set:html={JSON.stringify(scheduleFullLite)} />
<script src="/js/store.js" is:inline></script>
<script>
  import { buildDailyStats } from '../utils/dailyStats';

  const PROGRESS_TOOL = 'problem-progress';
  const schedule: any[] = JSON.parse(document.getElementById('home-daily-schedule')?.textContent || '[]');

  function toDayKey(d: Date) { return d.toISOString().slice(0, 10); }

  async function init() {
    const now = new Date();
    const todayKey = toDayKey(now);
    const dailyData = schedule.filter((r) => (r.publishedAt || '').slice(0, 10) <= todayKey);
    const bySlug = Object.fromEntries(dailyData.map((r: any) => [r.slug, r]));

    await (window as any).DCStore.init();
    const rows = await (window as any).DCStore.getAll(PROGRESS_TOOL);
    const progressMap: Record<string, any> = {};
    rows.forEach((row: any) => {
      if (!bySlug[row.id]) return;
      progressMap[row.id] = {
        solved: !!row.solved,
        solvedAt: row.solvedAt || null,
        attempts: Number(row.attempts || 0),
        attemptsByDay: row.attemptsByDay || {},
        solutionUnlockedAt: row.solutionUnlockedAt || null,
        solutionUnlockPenaltyApplied: !!row.solutionUnlockPenaltyApplied,
      };
    });

    const stats = buildDailyStats(dailyData, progressMap, now);

    const set = (id: string, val: string) => {
      const el = document.getElementById(id);
      if (el) el.textContent = val;
    };
    set('hp-streak', String(stats.currentStreak));
    set('hp-solved', String(stats.totalSolved));
    set('hp-best', String(stats.longestStreak));
  }

  init();
</script>

<style>
/* ── Hero ─────────────────────────────────────────────── */
.hp-hero {
  padding: 4rem 0 3rem;
  background:
    radial-gradient(ellipse 70% 60% at 75% -10%, color-mix(in srgb, var(--color-primary) 14%, transparent), transparent),
    radial-gradient(ellipse 60% 50% at 0% 10%, color-mix(in srgb, var(--color-primary) 7%, transparent), transparent);
}

.hp-hero__inner {
  display: grid;
  grid-template-columns: 1fr minmax(0, 480px);
  gap: 2.5rem 3.5rem;
  align-items: center;
}

@media (max-width: 920px) {
  .hp-hero__inner { grid-template-columns: 1fr; }
  .hp-hero__card { display: none; }
}

.hp-hero__eyebrow {
  display: inline-block;
  margin: 0 0 1rem;
  padding: 0.3rem 0.75rem;
  border-radius: 999px;
  border: 1px solid var(--color-border);
  background: var(--color-surface);
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.02em;
  color: var(--color-text-light);
}

.hp-hero__title {
  font-size: clamp(2.25rem, 5.5vw, 3.6rem);
  font-weight: 800;
  line-height: 1.05;
  letter-spacing: -0.03em;
  margin: 0 0 1.1rem;
}

.hp-hero__accent {
  background: linear-gradient(120deg, var(--color-primary), color-mix(in srgb, var(--color-primary) 55%, #22d3ee));
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.hp-hero__sub {
  font-size: 1.08rem;
  color: var(--color-text-light);
  line-height: 1.65;
  max-width: 38rem;
  margin: 0 0 1.6rem;
}

.hp-hero__ctas {
  display: flex;
  flex-wrap: wrap;
  gap: 0.65rem;
  margin-bottom: 1.4rem;
}

.hp-hero__pills {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}

.hp-pill {
  display: inline-flex;
  align-items: center;
  padding: 0.25rem 0.7rem;
  border-radius: 999px;
  border: 1px solid var(--color-border);
  background: var(--color-surface);
  font-size: 0.76rem;
  font-weight: 600;
  color: var(--color-text-light);
  text-decoration: none;
  transition: border-color 0.15s, color 0.15s, transform 0.15s;
}

.hp-pill:hover {
  border-color: var(--color-primary);
  color: var(--color-primary);
  text-decoration: none;
  transform: translateY(-1px);
}

/* Code card */
.hp-hero__card {
  border-radius: 14px;
  border: 1px solid var(--color-border);
  background: #0f172a;
  overflow: hidden;
  box-shadow: 0 28px 70px -24px rgba(0, 0, 0, 0.55);
}

.hp-hero__card-header {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.6rem 0.85rem;
  background: #1e293b;
  border-bottom: 1px solid #334155;
}

.hp-hero__card-dot { width: 11px; height: 11px; border-radius: 50%; }
.hp-hero__card-dot--red    { background: #ef4444; }
.hp-hero__card-dot--yellow { background: #f59e0b; }
.hp-hero__card-dot--green  { background: #22c55e; }

.hp-hero__card-filename {
  margin-left: 0.35rem;
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: #94a3b8;
}

.hp-hero__code {
  margin: 0;
  padding: 1.1rem 1.25rem;
  background: #0f172a;
  font-size: 0.82rem;
  line-height: 1.75;
  white-space: pre;
  overflow-x: auto;
  color: #e2e8f0;
  border-radius: 0;
}

.hp-c-keyword { color: #c084fc; }
.hp-c-fn      { color: #93c5fd; }
.hp-c-str     { color: #86efac; }

/* ── Stats strip ──────────────────────────────────────── */
.hp-stats-wrap {
  margin-top: 0.5rem;
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
  background: var(--color-surface);
  padding: 1.5rem 0;
}

.hp-stats {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 0.75rem;
}

@media (max-width: 760px) {
  .hp-stats { grid-template-columns: repeat(3, 1fr); }
}

@media (max-width: 420px) {
  .hp-stats { grid-template-columns: repeat(2, 1fr); }
}

.hp-stat-tile {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.15rem;
  padding: 0.6rem 0.4rem;
  border-radius: var(--radius-md);
  text-decoration: none;
  color: inherit;
  transition: background 0.15s, transform 0.15s;
}

.hp-stat-tile:hover {
  background: color-mix(in srgb, var(--color-primary) 8%, var(--color-surface));
  text-decoration: none;
  transform: translateY(-2px);
