---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import Subscribe from '../components/Subscribe.astro';
import {
  getBlogPostsSorted,
  getCourses,
  getTodaysProblem,
  getPastDailyProblems,
  getDailyScheduleFullLite,
  getProblem,
} from '../utils/contentLoader';
import '../styles/problems.scss';

const recentPosts = getBlogPostsSorted().slice(0, 3);
const firstPost = recentPosts[0];
const courses = getCourses();


const todaysProblem = getTodaysProblem();
const recentPotd = getPastDailyProblems().slice(0, 5);
const scheduleFullLite = getDailyScheduleFullLite();
const potdFull = todaysProblem ? getProblem(todaysProblem.slug) : null;

function textExcerpt(html: string, max = 200): string {
  if (!html) return '';
  const t = html.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
  return t.length > max ? t.slice(0, max).trimEnd() + '…' : t;
}

const potdExcerpt = potdFull ? textExcerpt(potdFull.descriptionHtml) : '';

function diffClass(d: string) {
  const x = d.toLowerCase();
  return x === 'easy' || x === 'medium' || x === 'hard' ? x : 'neutral';
}

const potdHref = todaysProblem ? `/problems/${todaysProblem.slug}` : '/problems';

const pageKeywords = [
  'daily coding challenge',
  'leetcode problems',
  'in-browser javascript editor',
  'developer tools',
  'coding tutorials',
  ...(todaysProblem ? [todaysProblem.title, todaysProblem.topic] : []),
].join(', ');

const jsonLdPotd = todaysProblem
  ? {
      '@context': 'https://schema.org',
      '@type': 'LearningResource',
      name: `Daily Challenge: ${todaysProblem.title}`,
      description: `Solve ${todaysProblem.title} — a ${todaysProblem.difficulty} ${todaysProblem.topic} problem — in the browser with an integrated editor.`,
      educationalLevel: todaysProblem.difficulty,
      learningResourceType: 'Coding Problem',
      url: `https://dailycoder.in/problems/${todaysProblem.slug}`,
      datePublished: todaysProblem.publishedAt || undefined,
    }
  : null;
---

<BaseLayout
  title="DailyCoder — Daily Coding Problems, Dev Tools & Tutorials"
  description="Solve today's coding challenge in-browser, read engineering deep-dives, take interactive courses, and use free developer tools. No signup needed."
  tags={pageKeywords.split(', ')}
>
  <Fragment slot="head">
    {jsonLdPotd && <script type="application/ld+json" set:html={JSON.stringify(jsonLdPotd)} />}
    <link rel="alternate" type="application/rss+xml" title="Daily Challenge RSS" href="/daily/problem/rss.xml" />
  </Fragment>

  <!-- ── HERO ─────────────────────────────────────────── -->
  <section class="hp-hero" aria-label="Site introduction">
    <div class="container hp-hero__inner">
      <div class="hp-hero__text">
        <h1 class="hp-hero__title">
          Learn. Build.<br /><span class="hp-hero__accent">Ship Daily.</span>
        </h1>
        <p class="hp-hero__sub">
          A daily coding problem in your browser, engineering deep-dives, hands-on courses,
          and 14+ free dev tools — all in one place.
        </p>
        <div class="hp-hero__ctas">
          <a href={potdHref} class="button">
            {todaysProblem ? "Solve today's problem" : 'Browse problems'}
          </a>
          <a href={firstPost ? `/blog/${firstPost.slug}` : '/blog'} class="button button--secondary">
            Latest post
          </a>
        </div>
        <div class="hp-hero__feature-pills">
          <a href="/problems" class="hp-pill">300+ Problems</a>
          <a href="/courses" class="hp-pill">Courses</a>
          <a href="/tools" class="hp-pill">14 Free Tools</a>
          <a href="/docs" class="hp-pill">Tech Guides</a>
        </div>
      </div>
      <div class="hp-hero__card" aria-hidden="true">
        <div class="hp-hero__card-header">
          <span class="hp-hero__card-dot hp-hero__card-dot--red"></span>
          <span class="hp-hero__card-dot hp-hero__card-dot--yellow"></span>
          <span class="hp-hero__card-dot hp-hero__card-dot--green"></span>
          <span class="hp-hero__card-filename">solution.js</span>
        </div>
        <pre class="hp-hero__code"><code><span class="hp-c-keyword">function</span> <span class="hp-c-fn">isValid</span>(s) {'{'}
  <span class="hp-c-keyword">const</span> map = {'{'}
    <span class="hp-c-str">&#39;)&#39;</span>: <span class="hp-c-str">&#39;(&#39;</span>,
    <span class="hp-c-str">&#39;]&#39;</span>: <span class="hp-c-str">&#39;[&#39;</span>,
    <span class="hp-c-str">&#39;&#125;&#39;</span>: <span class="hp-c-str">&#39;{'{'}&#39;</span>
  {'}'};
  <span class="hp-c-keyword">const</span> stack = [];
  <span class="hp-c-keyword">for</span> (<span class="hp-c-keyword">const</span> c <span class="hp-c-keyword">of</span> s) {'{'}
    <span class="hp-c-keyword">if</span> (map[c]) stack.pop() === map[c]
      || <span class="hp-c-keyword">return false</span>;
    <span class="hp-c-keyword">else</span> stack.push(c);
  {'}'}
  <span class="hp-c-keyword">return</span> !stack.length;
{'}'}</code></pre>
      </div>
    </div>
  </section>

  <!-- ── PROBLEM OF THE DAY ───────────────────────────── -->
  <section id="daily-challenge" class="hp-section container" aria-labelledby="potd-heading">
    <div class="hp-potd">
      <div class="hp-potd__aside">
        <p class="hp-eyebrow">Problem of the day</p>
        {todaysProblem && (
          <p class="hp-potd__date">{todaysProblem.publishedAt}</p>
        )}
        <div class="hp-potd__stats" aria-label="Your daily progress">
          <div class="hp-stat"><span class="hp-stat__val" id="hp-streak">—</span><span class="hp-stat__lbl">Streak</span></div>
          <div class="hp-stat"><span class="hp-stat__val" id="hp-solved">—</span><span class="hp-stat__lbl">Solved</span></div>
          <div class="hp-stat"><span class="hp-stat__val" id="hp-best">—</span><span class="hp-stat__lbl">Best</span></div>
        </div>
        <p class="hp-potd__stats-note">Sign in to sync progress across devices.</p>
        {recentPotd.length > 0 && (
          <div class="hp-potd__recents">
            <p class="hp-potd__recents-label">Recent picks</p>
            <ul>
              {recentPotd.map((p) => (
                <li>
                  <a href={`/problems/${p.slug}`}>{p.title}</a>
                  <span>{p.publishedAt}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>

      <div class="hp-potd__main">
        {todaysProblem ? (
          <>
            <div class="hp-potd__badges">
              <span class="p-badge p-badge--neutral">{todaysProblem.topic}</span>
              <span class={`p-badge p-badge--${diffClass(todaysProblem.difficulty)}`}>{todaysProblem.difficulty}</span>
              {todaysProblem.platform && <span class="p-badge p-badge--neutral">{todaysProblem.platform}</span>}
            </div>
            <h2 id="potd-heading" class="hp-potd__title">{todaysProblem.title}</h2>
            {potdExcerpt && <p class="hp-potd__excerpt">{potdExcerpt}</p>}
            {(todaysProblem.sampleInput || todaysProblem.sampleOutput) && (
              <div class="hp-potd__io">
                {todaysProblem.sampleInput && (
                  <div class="hp-potd__io-block">
                    <div class="hp-potd__io-label">Input</div>
                    <pre class="hp-potd__io-body">{todaysProblem.sampleInput}</pre>
                  </div>
                )}
                {todaysProblem.sampleOutput && (
                  <div class="hp-potd__io-block">
                    <div class="hp-potd__io-label">Output</div>
                    <pre class="hp-potd__io-body">{todaysProblem.sampleOutput}</pre>
                  </div>
                )}
              </div>
            )}
            <div class="hp-potd__actions">
              <a class="button" href={potdHref}>Solve in editor</a>
              <a class="hp-text-link" href="/problems">All problems →</a>
            </div>
          </>
        ) : (
          <>
            <h2 id="potd-heading" class="hp-potd__title">No problem scheduled today</h2>
            <p class="hp-potd__excerpt">Browse the full catalog and practise at your own pace.</p>
            <a class="button" href="/problems">Open problem list</a>
          </>
        )}
      </div>
    </div>
  </section>

  <!-- ── FEATURES STRIP ───────────────────────────────── -->
  <section class="hp-features-wrap" aria-label="Platform features">
    <div class="container hp-features">
      <a href="/problems" class="hp-feat">
        <span class="hp-feat__icon">⚡</span>
        <div>
          <h3>Problems</h3>
          <p>300+ curated problems with an in-browser JS runner, test cases, and progress sync.</p>
        </div>
      </a>
      <a href="/blog" class="hp-feat">
        <span class="hp-feat__icon">✍️</span>
        <div>
          <h3>Blog</h3>
          <p>Engineering deep-dives, architecture patterns, and practical career tips.</p>
        </div>
      </a>
      <a href="/courses" class="hp-feat">
        <span class="hp-feat__icon">🎓</span>
        <div>
          <h3>Courses</h3>
          <p>Hands-on interactive courses with lesson tracking and progress saved locally.</p>
        </div>
      </a>
      <a href="/tools" class="hp-feat">
        <span class="hp-feat__icon">🔧</span>
        <div>
          <h3>Tools</h3>
          <p>14 free, private, client-side developer tools. JSON, diff, regex, JWT and more.</p>
        </div>
      </a>
    </div>
  </section>

  <!-- ── BLOG POSTS ────────────────────────────────────── -->
  {recentPosts.length > 0 && (
    <section class="hp-section container" aria-labelledby="blog-heading">
      <div class="hp-section__hd">
        <h2 id="blog-heading">From the blog</h2>
        <a href="/blog" class="hp-text-link">View all →</a>
      </div>
      <div class="grid grid--3">
        {recentPosts.map((post) => (
          <PostCard
            title={post.title}
            description={post.description}
            date={new Date(post.date)}
            slug={post.slug}
            tags={post.tags}
            category={post.category}
            image={post.image}
            content={post.content}
          />
        ))}
      </div>
    </section>
  )}

  <!-- ── COURSES ───────────────────────────────────────── -->
  {courses.length > 0 && (
    <section class="hp-section container" aria-labelledby="courses-heading">
      <div class="hp-section__hd">
        <h2 id="courses-heading">Courses</h2>
        <a href="/courses" class="hp-text-link">View all →</a>
      </div>
      <div class="hp-course-list">
        {courses.slice(0, 4).map((course) => (
          <a href={`/courses/${course.slug}`} class="hp-course-row">
            <div class="hp-course-row__body">
              <span class="hp-course-row__title">{course.title}</span>
              <span class="hp-course-row__meta">{course.level} · {course.totalLessons} lessons · {course.duration}</span>
            </div>
            <span class="hp-course-row__arrow">→</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- ── TOOLS ─────────────────────────────────────────── -->
  <section class="hp-section container" aria-labelledby="tools-heading">
    <div class="hp-section__hd">
      <h2 id="tools-heading">Developer tools</h2>
      <a href="/tools" class="hp-text-link">All 14 tools →</a>
    </div>
    <p class="hp-tools-sub">Private & free — no data leaves your browser.</p>
    <div class="hp-tools">
      <a href="/tools/code-formatter" class="hp-tool"><span>&lt;/&gt;</span>Code Formatter</a>
      <a href="/tools/json-formatter" class="hp-tool"><span>&#123;&#125;</span>JSON Formatter</a>
      <a href="/tools/diff-checker" class="hp-tool"><span>±</span>Diff Checker</a>
      <a href="/tools/regex-tester" class="hp-tool"><span>.*</span>Regex Tester</a>
      <a href="/tools/color-picker" class="hp-tool"><span>◑</span>Color Picker</a>
      <a href="/tools/jwt-decoder" class="hp-tool"><span>🔑</span>JWT Decoder</a>
      <a href="/tools/qr-generator" class="hp-tool"><span>▣</span>QR Generator</a>
      <a href="/tools/markdown-preview" class="hp-tool"><span>MD</span>Markdown Preview</a>
    </div>
  </section>

  <!-- ── SUBSCRIBE ─────────────────────────────────────── -->
  <section class="hp-subscribe">
    <div class="container">
      <Subscribe />
    </div>
  </section>
</BaseLayout>

<script id="home-daily-schedule" type="application/json" set:html={JSON.stringify(scheduleFullLite)} />
<script src="/js/store.js" is:inline></script>
<script>
  import { buildDailyStats } from '../utils/dailyStats';

  const PROGRESS_TOOL = 'problem-progress';
  const schedule: any[] = JSON.parse(document.getElementById('home-daily-schedule')?.textContent || '[]');

  function toDayKey(d: Date) { return d.toISOString().slice(0, 10); }

  async function init() {
    const now = new Date();
    const todayKey = toDayKey(now);
    const dailyData = schedule.filter((r) => (r.publishedAt || '').slice(0, 10) <= todayKey);
    const bySlug = Object.fromEntries(dailyData.map((r: any) => [r.slug, r]));

    await (window as any).DCStore.init();
    const rows = await (window as any).DCStore.getAll(PROGRESS_TOOL);
    const progressMap: Record<string, any> = {};
    rows.forEach((row: any) => {
      if (!bySlug[row.id]) return;
      progressMap[row.id] = {
        solved: !!row.solved,
        solvedAt: row.solvedAt || null,
        attempts: Number(row.attempts || 0),
        attemptsByDay: row.attemptsByDay || {},
        solutionUnlockedAt: row.solutionUnlockedAt || null,
        solutionUnlockPenaltyApplied: !!row.solutionUnlockPenaltyApplied,
      };
    });

    const stats = buildDailyStats(dailyData, progressMap, now);

    const set = (id: string, val: string) => {
      const el = document.getElementById(id);
      if (el) el.textContent = val;
    };
    set('hp-streak', String(stats.currentStreak));
    set('hp-solved', String(stats.totalSolved));
    set('hp-best', String(stats.longestStreak));
  }

  init();
</script>

<style>
/* ── Hero ─────────────────────────────────────────────── */
.hp-hero {
  padding: 4rem 0 2.5rem;
  background: radial-gradient(ellipse 80% 55% at 50% -10%, color-mix(in srgb, var(--color-primary) 12%, transparent), transparent);
}

.hp-hero__inner {
  display: grid;
  grid-template-columns: 1fr minmax(0, 460px);
  gap: 2.5rem 3rem;
  align-items: center;
}

@media (max-width: 900px) {
  .hp-hero__inner {
    grid-template-columns: 1fr;
  }
  .hp-hero__card {
    display: none;
  }
}

.hp-hero__title {
  font-size: clamp(2.25rem, 5vw, 3.5rem);
  font-weight: 800;
  line-height: 1.05;
  letter-spacing: -0.03em;
  margin: 0 0 1rem;
}

.hp-hero__accent {
  color: var(--color-primary);
}

.hp-hero__sub {
  font-size: 1.05rem;
  color: var(--color-text-light);
  line-height: 1.65;
  max-width: 38rem;
  margin: 0 0 1.5rem;
}

.hp-hero__ctas {
  display: flex;
  flex-wrap: wrap;
  gap: 0.65rem;
  margin-bottom: 1.35rem;
}

.hp-hero__feature-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}

.hp-pill {
  display: inline-flex;
  align-items: center;
  padding: 0.2rem 0.65rem;
  border-radius: 999px;
  border: 1px solid var(--color-border);
  background: var(--color-surface);
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--color-text-light);
  text-decoration: none;
  transition: border-color 0.15s, color 0.15s;
}

.hp-pill:hover {
  border-color: var(--color-primary);
  color: var(--color-primary);
  text-decoration: none;
}

/* Code card */
.hp-hero__card {
  border-radius: 12px;
  border: 1px solid var(--color-border);
  background: #0f172a;
  overflow: hidden;
  box-shadow: 0 24px 60px -20px rgba(0,0,0,0.5);
}

.hp-hero__card-header {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.6rem 0.85rem;
  background: #1e293b;
  border-bottom: 1px solid #334155;
}

.hp-hero__card-dot {
  width: 11px;
  height: 11px;
  border-radius: 50%;
}

.hp-hero__card-dot--red    { background: #ef4444; }
.hp-hero__card-dot--yellow { background: #f59e0b; }
.hp-hero__card-dot--green  { background: #22c55e; }

.hp-hero__card-filename {
  margin-left: 0.35rem;
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: #94a3b8;
}

.hp-hero__code {
  margin: 0;
  padding: 1.1rem 1.25rem;
  background: #0f172a;
  font-size: 0.82rem;
  line-height: 1.7;
  white-space: pre;
  overflow-x: auto;
  color: #e2e8f0;
  border-radius: 0;
}

/* syntax colours */
.hp-c-keyword { color: #c084fc; }
.hp-c-fn      { color: #93c5fd; }
.hp-c-str     { color: #86efac; }

/* ── Sections ─────────────────────────────────────────── */
.hp-section {
  padding-top: 3rem;
  padding-bottom: 1.5rem;
}

.hp-section__hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 1.25rem;
  gap: 0.75rem;
}

.hp-section__hd h2 {
  margin: 0;
  font-size: 1.3rem;
  font-weight: 800;
  letter-spacing: -0.02em;
}

.hp-text-link {
  font-size: 0.88rem;
  font-weight: 600;
  white-space: nowrap;
}

/* ── POTD ─────────────────────────────────────────────── */
.hp-potd {
  display: grid;
  grid-template-columns: 220px 1fr;
  gap: 2rem;
  border: 1px solid var(--color-border);
  border-radius: 16px;
  background: var(--color-surface);
  overflow: hidden;
}

@media (max-width: 768px) {
  .hp-potd {
    grid-template-columns: 1fr;
  }
  .hp-potd__aside {
    border-right: none !important;
    border-bottom: 1px solid var(--color-border);
  }
}

.hp-potd__aside {
  border-right: 1px solid var(--color-border);
  background: color-mix(in srgb, var(--color-primary) 5%, var(--color-surface));
  padding: 1.25rem 1rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.hp-eyebrow {
  margin: 0;
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--color-primary);
}

.hp-potd__date {
  margin: -0.25rem 0 0;
  font-size: 0.78rem;
  color: var(--color-text-light);
  font-variant-numeric: tabular-nums;
}

.hp-potd__stats {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 0.35rem;
