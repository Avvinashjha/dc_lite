}

.hp-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0.4rem 0.25rem;
  border-radius: 8px;
  border: 1px solid var(--color-border);
  background: var(--color-background);
  gap: 0.1rem;
}

.hp-stat__val {
  font-size: 1rem;
  font-weight: 800;
  line-height: 1;
  font-variant-numeric: tabular-nums;
}

.hp-stat__lbl {
  font-size: 0.55rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  font-weight: 600;
  color: var(--color-text-light);
}

.hp-potd__stats-note {
  margin: 0;
  font-size: 0.68rem;
  color: var(--color-text-light);
  line-height: 1.4;
}

.hp-potd__recents {
  margin-top: 0.25rem;
}

.hp-potd__recents-label {
  margin: 0 0 0.4rem;
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--color-text-light);
}

.hp-potd__recents ul {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.05rem;
}

.hp-potd__recents li {
  margin: 0;
  border-top: 1px solid var(--color-border);
  padding: 0.3rem 0;
  display: flex;
  flex-direction: column;
  gap: 0.05rem;
}

.hp-potd__recents li:first-child {
  border-top: none;
  padding-top: 0;
}

