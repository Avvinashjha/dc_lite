  font-size: 0.8rem;
  font-weight: 600;
  line-height: 1.3;
}

.hp-potd__recents span {
  font-size: 0.65rem;
  color: var(--color-text-light);
}

.hp-potd__main {
  padding: 1.5rem 1.5rem 1.5rem 0;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  min-width: 0;
}

@media (max-width: 768px) {
  .hp-potd__main {
    padding: 1.25rem;
  }
}

.hp-potd__badges {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
}

.hp-potd__title {
  margin: 0;
  font-size: clamp(1.4rem, 3vw, 1.75rem);
  font-weight: 800;
  letter-spacing: -0.025em;
  line-height: 1.15;
}

.hp-potd__excerpt {
  margin: 0;
  font-size: 0.9rem;
  color: var(--color-text-light);
  line-height: 1.6;
}

.hp-potd__io {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.65rem;
}

@media (max-width: 560px) {
  .hp-potd__io {
    grid-template-columns: 1fr;
  }
}

.hp-potd__io-block {
  border: 1px solid var(--color-border);
  border-radius: 8px;
  overflow: hidden;
}

.hp-potd__io-label {
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  padding: 0.28rem 0.6rem;
  background: var(--color-code-bg);
  color: var(--color-text-light);
