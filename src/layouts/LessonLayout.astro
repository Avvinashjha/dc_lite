---
import BaseLayout from "./BaseLayout.astro";
import VideoEmbed from "../components/VideoEmbed.astro";
import Quiz from "../components/Quiz.astro";
import Exercise from "../components/Exercise.astro";
import QuizPlayer from "../components/QuizPlayer";
import { parseMarkdown } from "../utils/markdown";
import { extractBlocks } from "../utils/parseBlocks";
import type { Course, Lesson } from "../types/post";
import type { Quiz as QuizType } from "../types/quiz";
import "../styles/quiz.scss";

interface Props {
  lesson: Lesson;
  course: Course;
  prevLesson?: {
    courseSlug: string;
    moduleSlug: string;
    slug: string;
    title: string;
  } | null;
  nextLesson?: {
    courseSlug: string;
    moduleSlug: string;
    slug: string;
    title: string;
  } | null;
  quiz?: QuizType | null;
  quizApiUrl?: string;
}

const {
  lesson,
  course,
  prevLesson,
  nextLesson,
  quiz = null,
  quizApiUrl = "",
} = Astro.props;
const { cleanMarkdown, blocks } = extractBlocks(lesson.content);
const htmlParts = parseMarkdown(cleanMarkdown).split(/<!--BLOCK_(\d+)-->/);
const hasMermaid = /```mermaid\b/.test(cleanMarkdown);
const lessonCourseSlug = course.slug;
const lessonSlug = lesson.slug;
const lessonModuleSlug = lesson.moduleSlug;
const isQuizLesson = lesson.type === "quiz";
const passingScore = lesson.passingScore ?? 70;
const quizSlug = quiz?.slug ?? "";

// Ordered structure consumed by DCCourseProgress for completion + gating.
const courseStructure = {
  slug: course.slug,
  modules: course.resolvedModules.map((m) => ({
    slug: m.slug,
    title: m.title,
    lessons: m.lessons.map((l) => ({ slug: l.slug, type: l.type, quizSlug: l.quizSlug ?? "" })),
  })),
};

function lessonIcon(type: string): string {
  if (type === "video") {
    return `<svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M10 8.5l5 3.5-5 3.5z" fill="currentColor" stroke="none"/></svg>`;
  }
  if (type === "quiz") {
    return `<svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M9.6 9.2a2.4 2.4 0 1 1 3.4 2.2c-.8.4-1.1.9-1.1 1.7"/><circle cx="12" cy="16.4" r="0.6" fill="currentColor" stroke="none"/></svg>`;
  }
  return `<svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="7" x2="19" y2="7"/><line x1="5" y1="12" x2="19" y2="12"/><line x1="5" y1="17" x2="13" y2="17"/></svg>`;
}

const checkSvg = `<svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5l4.5 4.5L19 7"/></svg>`;
const chevronSvg = `<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>`;
---

<BaseLayout
  title={`${lesson.title} | ${course.title} | DailyCoder`}
  description={`${lesson.title} - ${course.title}`}
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Courses", href: "/courses" },
    { label: course.title, href: `/courses/${course.slug}` },
    { label: lesson.title, href: Astro.url.pathname },
  ]}
>
  <div class="lesson-layout lesson-layout--drawer-open" data-lesson-layout>
    <!-- Drawer backdrop (mobile) -->
    <div class="lesson-drawer-backdrop" data-drawer-backdrop></div>

    <!-- Sidebar drawer -->
    <aside class="lesson-sidebar" data-lesson-sidebar>
      <div class="lesson-sidebar__head">
        <a href={`/courses/${course.slug}`} class="lesson-sidebar__back">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6l-6 6 6 6"/></svg>
          <span>{course.title}</span>
        </a>
        <button
          type="button"
          class="lesson-sidebar__close"
          data-drawer-close
          aria-label="Close course contents"
        >
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
        </button>
      </div>

      <div class="lesson-progress" data-course-progress>
        <div class="lesson-progress__meta">
          <span class="lesson-progress__label">0% complete</span>
        </div>
        <div class="lesson-progress__track">
          <span class="lesson-progress__fill" style="width: 0%"></span>
        </div>
      </div>

      <nav class="lesson-sidebar__nav">
        {
          course.resolvedModules.map((mod, modIdx) => (
            <div
              class={`lesson-sidebar__module ${mod.slug === lesson.moduleSlug ? "" : "lesson-sidebar__module--collapsed"}`}
              data-module-index={modIdx}
              data-module-slug={mod.slug}
            >
              <button type="button" class="lesson-sidebar__module-header" data-module-toggle>
                <span class="lesson-sidebar__chevron" set:html={chevronSvg} />
                <span class="lesson-sidebar__module-num">{modIdx + 1}</span>
                <span class="lesson-sidebar__module-title">{mod.title}</span>
                <span class="lesson-sidebar__lock" data-module-lock hidden>
                  <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/></svg>
                </span>
                <span class="lesson-sidebar__module-count">{mod.lessons.length}</span>
              </button>
              <div class="lesson-sidebar__lessons-wrap">
                <ul class="lesson-sidebar__lessons">
                  {mod.lessons.map((l) => (
                    <li>
                      <a
                        href={`/courses/${course.slug}/${mod.slug}/${l.slug}`}
                        data-lesson-key={`${mod.slug}/${l.slug}`}
                        class={`lesson-sidebar__link ${l.slug === lesson.slug && mod.slug === lesson.moduleSlug ? "lesson-sidebar__link--active" : ""}`}
                      >
                        <span class="lesson-sidebar__status">
                          <span class="lesson-sidebar__check" data-lesson-check hidden set:html={checkSvg} />
                          <span class="lesson-sidebar__icon" set:html={lessonIcon(l.type)} />
                        </span>
                        <span class="lesson-sidebar__text">{l.title}</span>
                        <span class="lesson-sidebar__duration">{l.duration}</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))
        }
      </nav>
    </aside>

    <!-- Content -->
    <article class="lesson-content">
      <div class="lesson-topbar">
        <button
          type="button"
          class="lesson-drawer-toggle"
          data-drawer-toggle
          aria-label="Toggle course contents"
        >
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>
          <span>Contents</span>
        </button>
      </div>

      <div class="lesson-content__header">
        <span class="tag" style="text-transform: capitalize;"
          >{lesson.type}</span
        >
        <span style="color: var(--color-text-light); font-size: 0.875rem;"
          >{lesson.duration}</span
        >
        <span class="lesson-complete-badge" data-lesson-complete-badge hidden
          >✓ Completed</span
        >
      </div>

      <!-- Locked-module gate (revealed client-side when prerequisites are unmet) -->
      <div class="lesson-gate" data-lesson-gate hidden>
        <div class="lesson-gate__icon">🔒</div>
        <h2 class="lesson-gate__title">This lesson is locked</h2>
        <p class="lesson-gate__text">
          Finish the previous module to unlock <strong>{lesson.title}</strong>.
        </p>
        <a href={`/courses/${course.slug}`} class="button button--primary"
          >Back to course overview</a
        >
      </div>

      <div class="lesson-body" data-lesson-body>
        <div class="article__content">
          {
            htmlParts.map((part, i) => {
              if (i % 2 === 0) {
                return <div set:html={part} />;
              }
              const blockIdx = parseInt(part);
              const block = blocks[blockIdx];
              if (!block) return null;
              if (block.type === "video")
                return <VideoEmbed url={block.url} title={block.title} />;
              if (block.type === "quiz")
                return (
                  <Quiz
                    question={block.question}
                    options={block.options}
                    answer={block.answer}
                    explanation={block.explanation}
                  />
                );
              if (block.type === "exercise")
                return (
                  <Exercise
                    title={block.title}
                    description={block.description}
                    starterCode={block.starterCode}
                  />
                );
              return null;
            })
          }
        </div>

        {
          isQuizLesson && quiz && (
            <div class="lesson-quiz">
              <p class="lesson-quiz__note">
                Score <strong>{passingScore}%</strong> or higher on this quiz to
                complete the lesson.
              </p>
              <QuizPlayer client:load quiz={quiz} />
            </div>
          )
        }
        {
          isQuizLesson && !quiz && (
            <p class="lesson-quiz__missing">
              This quiz is not available yet. Please check back soon.
            </p>
          )
        }

        {
          !isQuizLesson && (
            <div class="lesson-complete" data-lesson-complete-zone>
              <button
                type="button"
                class="button button--primary"
                data-mark-complete
              >
                Mark as complete
              </button>
              <button
                type="button"
                class="button button--outline"
                data-mark-incomplete
                hidden
              >
                ✓ Completed — Undo
              </button>
            </div>
          )
        }

        <!-- Nav -->
        <div class="lesson-nav">
          {
            prevLesson ? (
              <a
                href={`/courses/${prevLesson.courseSlug}/${prevLesson.moduleSlug}/${prevLesson.slug}`}
                class="button button--secondary"
              >
                &larr; {prevLesson.title}
              </a>
            ) : (
              <span />
            )
          }
          {
            nextLesson ? (
              <a
                href={`/courses/${nextLesson.courseSlug}/${nextLesson.moduleSlug}/${nextLesson.slug}`}
                class="button"
              >
                {nextLesson.title} &rarr;
              </a>
            ) : (
              <a href={`/courses/${course.slug}`} class="button">
                Back to Course
              </a>
            )
          }
        </div>
      </div>
    </article>
  </div>
</BaseLayout>

{
  isQuizLesson && quiz && (
    <script set:html={`window.__dcQuizApiUrl = ${JSON.stringify(quizApiUrl)};`} is:inline />
  )
}
<script src="/js/store.js" is:inline></script>
<script src="/js/course-progress.js" is:inline></script>
{
  hasMermaid && (
    <script type="module" is:inline>
      import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs";

      mermaid.initialize({
        startOnLoad: true,
        theme: "dark",
        securityLevel: "strict",
      });
    </script>
  )
}
<script
  is:inline
  define:vars={{
    structure: courseStructure,
    lessonCourseSlug,
    lessonModuleSlug,
    lessonSlug,
    isQuizLesson,
    passingScore,
    quizSlug,
  }}
>
  (function () {
    if (typeof DCCourseProgress === "undefined") return;
    var CP = DCCourseProgress;

    // Expose the structure so DCCourseProgress can build the structured sync
    // payload (course_enrollments / course_module_progress / course_quiz_scores).
    window.__dcCourseStructure = structure;

    var modIndex = -1;
    for (var i = 0; i < structure.modules.length; i++) {
      if (structure.modules[i].slug === lessonModuleSlug) {
        modIndex = i;
        break;
      }
    }

    // ── Auth gating ─────────────────────────────────────────────────────────
    // Course progress is server-backed and per-user, so all progress actions
    // require a signed-in user. Explicit actions (mark complete, undo, quiz)
    // prompt sign-in; passive ones (auto-complete, time tracking) silently skip.
    function isSignedIn() {
      return (typeof window.isUserSignedIn === "function")
        ? window.isUserSignedIn()
        : !!window.__dcAuthUser;
    }
    function requireAuthAction(reason, fn) {
      if (isSignedIn()) { fn(); return; }
      if (typeof window.requireAuth === "function") {
        window.requireAuth(reason, function () {
          // After sign-in, hydrate the user's real server progress FIRST, then
          // run the action on top of it. This guarantees we never overwrite
          // existing progress with an empty payload, and the in-flight-push
          // guard in DCCourseProgress stops the later authchange hydrate from
          // clobbering this write.
          hydrateAndRefresh().then(fn);
        });
      }
    }
    var AUTH_REASON = "Sign in or sign up to track your course progress";

    function renderSidebar(row) {
      document.querySelectorAll("[data-lesson-key]").forEach(function (a) {
        var k = a.getAttribute("data-lesson-key");
        var done = row.completedLessons.indexOf(k) !== -1;
        var check = a.querySelector("[data-lesson-check]");
        if (check) check.hidden = !done;
        a.classList.toggle("lesson-sidebar__link--done", done);
      });

      document.querySelectorAll("[data-module-index]").forEach(function (el) {
        var idx = parseInt(el.getAttribute("data-module-index"), 10);
        var unlocked = CP.moduleUnlocked(structure, row, idx);
        var lock = el.querySelector("[data-module-lock]");
        if (lock) lock.hidden = unlocked;
        el.classList.toggle("lesson-sidebar__module--locked", !unlocked);
        el.querySelectorAll("[data-lesson-key]").forEach(function (a) {
          a.classList.toggle("lesson-sidebar__link--locked", !unlocked);
        });
      });

      var c = CP.counts(structure, row);
      var fill = document.querySelector(".lesson-progress__fill");
      var label = document.querySelector(".lesson-progress__label");
      if (fill) fill.style.width = c.percent + "%";
      if (label) label.textContent = c.percent + "% complete";
    }

    function setCompletedUI(done) {
      var badge = document.querySelector("[data-lesson-complete-badge]");
      if (badge) badge.hidden = !done;
      var markBtn = document.querySelector("[data-mark-complete]");
      var undoBtn = document.querySelector("[data-mark-incomplete]");
      if (markBtn) markBtn.hidden = done;
      if (undoBtn) undoBtn.hidden = !done;
    }

    function applyGate(row) {
      var locked = modIndex > 0 && !CP.moduleUnlocked(structure, row, modIndex);
      var gate = document.querySelector("[data-lesson-gate]");
      var body = document.querySelector("[data-lesson-body]");
      if (gate) gate.hidden = !locked;
      if (body) body.hidden = locked;
      return locked;
    }

    function refresh() {
      return CP.getRow(lessonCourseSlug).then(function (row) {
        var safe = row || { completedLessons: [], quizScores: {} };
        renderSidebar(safe);
        applyGate(safe);
        if (!isQuizLesson) {
          setCompletedUI(CP.isLessonComplete(safe, lessonModuleSlug, lessonSlug));
        }
        return safe;
      });
    }

    // Preserve existing "resume" behaviour: record last visited lesson when
    // enrolled. Requires auth (server-backed); silently skips otherwise.
    function trackLastLesson() {
      if (!isSignedIn()) return Promise.resolve();
      return CP.getRow(lessonCourseSlug).then(function (row) {
        if (!row || !row.enrolledAt) return;
        return CP.trackLastLesson(lessonCourseSlug, lessonModuleSlug, lessonSlug);
      });
    }

    // ── Smart active-time tracking ──────────────────────────────────────────
    // Count only seconds where the tab is visible and the user is not idle.
    var IDLE_MS = 60000;        // no interaction for 60s ⇒ paused
    var FLUSH_MS = 15000;       // persist accumulated time every 15s
    var pendingSec = 0;         // un-persisted active seconds
    var lastTick = Date.now();
    var lastActivity = Date.now();

    function isActiveNow() {
      return document.visibilityState === "visible" && (Date.now() - lastActivity) < IDLE_MS;
    }
    function tick() {
      var now = Date.now();
      if (isActiveNow()) pendingSec += (now - lastTick) / 1000;
      lastTick = now;
    }
    function flushTime() {
      tick();
      var secs = Math.round(pendingSec);
      if (secs <= 0) return Promise.resolve();
      if (!isSignedIn()) { pendingSec = 0; return Promise.resolve(); } // no anon tracking
      pendingSec -= secs;
      return CP.addTime(lessonCourseSlug, lessonModuleSlug, lessonSlug, secs);
    }
    ["mousemove", "keydown", "scroll", "click", "touchstart"].forEach(function (evt) {
      window.addEventListener(evt, function () { lastActivity = Date.now(); }, { passive: true });
    });
    setInterval(tick, 1000);
    setInterval(flushTime, FLUSH_MS);
    document.addEventListener("visibilitychange", function () {
      if (document.visibilityState === "hidden") flushTime();
      else { lastTick = Date.now(); lastActivity = Date.now(); }
    });
    // Final flush on unload: persist locally and beacon the structured payload
    // (a normal fetch may be cancelled during page teardown).
    window.addEventListener("pagehide", function () {
      if (!isSignedIn()) return;
      tick();
      var secs = Math.round(pendingSec);
      if (secs > 0) { pendingSec = 0; CP.addTime(lessonCourseSlug, lessonModuleSlug, lessonSlug, secs); }
      beaconCourseProgress();
    });

    function beaconCourseProgress() {
      if (typeof DCSyncService === "undefined" || !DCSyncService.isActive()) return;
      if (typeof navigator === "undefined" || !navigator.sendBeacon) return;
      var url = DCSyncService._getScriptUrl ? DCSyncService._getScriptUrl() : null;
      if (!url) return;
      CP.getRow(lessonCourseSlug).then(function (row) {
        if (!row) return;
        var payload = CP.buildStructuredPayload(structure, row);
        var token = (typeof window.getFirebaseIdToken === "function") ? window.getFirebaseIdToken() : Promise.resolve("");
        Promise.resolve(token).then(function (tok) {
          if (!tok) return;
          var body = JSON.stringify(Object.assign({ action: "saveCourseProgress", idToken: tok }, payload));
          try { navigator.sendBeacon(url, new Blob([body], { type: "text/plain" })); } catch (e) {}
        });
      });
    }

    // ── Smart auto-completion for reading lessons ───────────────────────────
    // Mark a non-quiz lesson complete once the reader has reached the end of the
    // content AND spent a minimum dwell time on it. The manual button remains.
    var MIN_DWELL_MS = 30000;
    var autoCompleteArmed = !isQuizLesson;
    var lessonStart = Date.now();
    function maybeAutoComplete() {
      if (!autoCompleteArmed) return;
      if (!isSignedIn()) return; // course progress is for signed-in users only
      var body = document.querySelector("[data-lesson-body]");
      if (!body || body.hidden) return; // gated/locked
      if ((Date.now() - lessonStart) < MIN_DWELL_MS) return;
      var rect = body.getBoundingClientRect();
      var reachedEnd = rect.bottom <= (window.innerHeight || document.documentElement.clientHeight) + 80;
      if (!reachedEnd) return;
      autoCompleteArmed = false;
      CP.getRow(lessonCourseSlug).then(function (row) {
        if (row && CP.isLessonComplete(row, lessonModuleSlug, lessonSlug)) return;
        CP.markLessonComplete(lessonCourseSlug, lessonModuleSlug, lessonSlug).then(refresh);
      });
    }
    if (!isQuizLesson) {
      window.addEventListener("scroll", maybeAutoComplete, { passive: true });
      window.addEventListener("resize", maybeAutoComplete, { passive: true });
      setInterval(maybeAutoComplete, 5000); // also covers short pages / no-scroll
    }

    var markBtn = document.querySelector("[data-mark-complete]");
    if (markBtn) {
      markBtn.addEventListener("click", function () {
        requireAuthAction(AUTH_REASON, function () {
          CP.markLessonComplete(lessonCourseSlug, lessonModuleSlug, lessonSlug).then(refresh);
        });
      });
    }
    var undoBtn = document.querySelector("[data-mark-incomplete]");
    if (undoBtn) {
      undoBtn.addEventListener("click", function () {
        requireAuthAction(AUTH_REASON, function () {
          CP.unmarkLessonComplete(lessonCourseSlug, lessonModuleSlug, lessonSlug).then(refresh);
        });
      });
    }

    if (isQuizLesson) {
      window.addEventListener("dc:quizcompleted", function (ev) {
        if (!ev.detail || ev.detail.slug !== quizSlug) return;
        requireAuthAction(AUTH_REASON, function () {
          CP.recordQuizScore(
            lessonCourseSlug,
            lessonModuleSlug,
            lessonSlug,
            ev.detail.percent,
            passingScore
          ).then(refresh);
        });
      });
    }

    // Pull structured cross-device progress on sign-in, then re-render.
    function hydrateAndRefresh() {
      if (typeof DCSyncService !== "undefined" && DCSyncService.isActive() &&
          typeof DCSyncService.pullCourseProgress === "function") {
        return DCSyncService.pullCourseProgress(lessonCourseSlug).then(refresh);
      }
      return refresh();
    }
    window.addEventListener("dc:authchange", function () {
      setTimeout(hydrateAndRefresh, 600);
    });

    // Server is the source of truth: hydrate from it first, then render and
    // record the resume pointer. (No IndexedDB; progress lives in memory +
    // the Google Sheet.)
    hydrateAndRefresh().then(trackLastLesson);
  })();
</script>

<script is:inline>
  (function () {
    var layout = document.querySelector("[data-lesson-layout]");
    if (!layout) return;
    var desktopMq = window.matchMedia("(min-width: 1024px)");

    function openDrawer() {
      layout.classList.add("lesson-layout--drawer-open");
    }
    function closeDrawer() {
      layout.classList.remove("lesson-layout--drawer-open");
    }
    function toggleDrawer() {
      layout.classList.toggle("lesson-layout--drawer-open");
    }

    // Default state: open on desktop, closed on smaller screens.
    if (desktopMq.matches) openDrawer();
    else closeDrawer();

    document.querySelectorAll("[data-drawer-toggle]").forEach(function (b) {
      b.addEventListener("click", toggleDrawer);
    });
    document.querySelectorAll("[data-drawer-close]").forEach(function (b) {
      b.addEventListener("click", closeDrawer);
    });
    var backdrop = layout.querySelector("[data-drawer-backdrop]");
    if (backdrop) backdrop.addEventListener("click", closeDrawer);

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape" && !desktopMq.matches) closeDrawer();
    });

    // Close the drawer after picking a lesson on small screens.
    layout.querySelectorAll(".lesson-sidebar__link").forEach(function (a) {
      a.addEventListener("click", function () {
        if (!desktopMq.matches) closeDrawer();
      });
    });

    // Accordion: collapse/expand a module section.
    layout.querySelectorAll("[data-module-toggle]").forEach(function (btn) {
      btn.addEventListener("click", function () {
        var mod = btn.closest(".lesson-sidebar__module");
        if (mod) mod.classList.toggle("lesson-sidebar__module--collapsed");
      });
    });
  })();
</script>

<style>
  .lesson-layout {
    position: relative;
    min-height: calc(100vh - 160px);
    max-width: 100vw;
    overflow-x: hidden;
    transition: padding-left var(--transition-base);
  }

  /* ---------- Drawer ---------- */
  .lesson-sidebar {
    position: fixed;
    top: 52px;
    left: 0;
    bottom: 0;
    width: 312px;
    z-index: 60;
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border-right: 1px solid var(--color-border);
