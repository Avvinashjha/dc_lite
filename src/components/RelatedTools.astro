---
import type { ToolEntry } from '../data/tools';

interface Props {
  tools: (ToolEntry & { category?: string })[];
  heading?: string;
}

const { tools, heading = 'Related tools' } = Astro.props;
---

{tools.length > 0 && (
  <section class="rel">
    <h2 class="rel__heading">{heading}</h2>
    <div class="rel__grid">
      {tools.map((t) => (
        <a href={t.href} class="rel__card">
          <span class="rel__icon">{t.icon}</span>
          <span class="rel__body">
            <span class="rel__name">{t.name}</span>
            <span class="rel__desc">{t.desc}</span>
          </span>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .rel {
    margin-top: 1.75rem;
  }
  .rel__heading {
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin: 0 0 0.85rem;
  }
  .rel__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.6rem;
  }
  .rel__card {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    padding: 0.8rem 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    text-decoration: none;
    color: inherit;
    transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
  }
  .rel__card:hover {
    transform: translateY(-2px);
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
    text-decoration: none;
    color: inherit;
  }
  .rel__icon {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    background: var(--color-code-bg);
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 1rem;
  }
  .rel__body {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }
  .rel__name {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--color-text);
  }
  .rel__desc {
    font-size: 0.76rem;
    line-height: 1.45;
    color: var(--color-text-light);
  }
</style>
